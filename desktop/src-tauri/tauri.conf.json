{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkNote",
  "version": "0.1.0",
  "identifier": "com.linknote.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LinkNote",
        "url": "http://127.0.0.1:8000",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
